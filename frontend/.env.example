# Frontend Environment Variables
# Copy this file to .env.local and fill in with your values

# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api

# Auth Configuration
VITE_JWT_SECRET=dev-secret-key-change-in-production

# App Configuration
VITE_APP_NAME=WeTransfer Clone
VITE_MAX_FILE_SIZE_MB=2
VITE_FILE_EXPIRATION_MINUTES=2

# Feature Flags
VITE_ENABLE_DRAG_DROP=false
VITE_ENABLE_MULTIPLE_UPLOAD=false
VITE_ENABLE_SHARE_LINKS=false
