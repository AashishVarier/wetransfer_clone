# Backend Environment Variables
# Copy this file to .env and fill in your values

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=YOUR_ACCOUNT_ID

# S3 Configuration
S3_BUCKET=wetransfer-clone-files-<your-username>

# DynamoDB Configuration
DYNAMODB_TABLE=wetransfer-metadata
DYNAMODB_ENDPOINT=http://localhost:8000

# SQS Configuration
SQS_QUEUE_NAME=wetransfer-delete-queue
SQS_ENDPOINT=http://localhost:9324

# File Upload Configuration
MAX_FILE_SIZE=2097152
DELETION_DELAY_SECONDS=120
UPLOAD_PRESIGNED_URL_EXPIRY=3600

# Rate Limiting Configuration
RATE_LIMIT_UPLOADS_PER_MINUTE=10
RATE_LIMIT_DOWNLOADS_PER_MINUTE=20

# Download Presigned URL Expiry (24 hours)
DOWNLOAD_PRESIGNED_URL_EXPIRY=86400

# DynamoDB TTL Configuration
ITEM_TTL_SECONDS=300
