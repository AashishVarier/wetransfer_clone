# Backend Environment Variables
# Copy this file to .env and fill in with your values

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Service Configuration
S3_BUCKET_NAME=wetransfer-clone-files-dev
DYNAMODB_TABLE_NAME=wetransfer-clone-metadata-dev
DYNAMODB_RATELIMIT_TABLE=wetransfer-clone-ratelimit-dev

# File Configuration
FILE_EXPIRATION_MINUTES=2
MAX_FILE_SIZE_MB=2

# Authentication
JWT_SECRET=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_SECONDS=3600

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MINUTES=15

# Logging
LOG_LEVEL=INFO

# Deployment
DEPLOYMENT_STAGE=dev
